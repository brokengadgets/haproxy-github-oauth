# ── GitHub OAuth App ──────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps → New
# Callback URL: https://auth.brokengadgets.io/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# GitHub org that users must belong to
GITHUB_ORG=brokengadgets

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate: openssl rand -hex 32
JWT_SECRET=change-me-minimum-32-characters-long

# ── Service URLs ──────────────────────────────────────────────────────────────
# Public URL of this service (no trailing slash)
BASE_URL=https://auth.brokengadgets.io

# Cookie domain — leading dot covers all subdomains
COOKIE_DOMAIN=.brokengadgets.io

# Listen address (default: :4180)
LISTEN_ADDR=:4180

# Session duration; Go duration string (default: 8h)
SESSION_DURATION=8h

# Optional: comma-separated org/team-slug allow list.
# Empty = any member of GITHUB_ORG can log in (team ACLs still apply per backend).
ALLOWED_TEAMS=

# ── VPN — path to your OpenVPN client config (.ovpn) ─────────────────────────
# Used by scripts/bootstrap-secrets.sh to push the config to Secret Manager.
# The file itself must NOT be committed — it is gitignored.
OPENVPN_CONFIG_FILE=/path/to/client.ovpn

# ── MIAB cert sync & secrets bootstrap ───────────────────────────────────────
# Used by scripts/cert-sync.sh and scripts/bootstrap-secrets.sh
MIAB_HOST=box.brokengadgets.io
MIAB_USER=admin@brokengadgets.io
MIAB_PASSWORD=your-miab-admin-password

# Used by scripts/cert-sync.sh directly (not stored in GCP)
DOMAIN=brokengadgets.io
HAPROXY_CERT_DIR=/etc/haproxy/certs
